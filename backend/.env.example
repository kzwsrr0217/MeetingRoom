# backend/.env.example — copy to .env and fill in values

USE_MOCK_DATA=false
PORT=3000

# Frontend origin(s) allowed by CORS (comma-separated). For the podman prod setup
# the frontend proxies /api same-origin, so this only matters for the split dev setup.
FRONTEND_URL=http://localhost:5173

# Shared secret protecting admin/mutating endpoints (rooms CRUD, token swap,
# preset names, check-in). Leave empty for local/mock work — the guard is then
# fail-open and logs a warning. Set a strong value before exposing the backend.
ADMIN_API_KEY=

# Short-lived per-room status cache (ms) — smooths kiosk + admin poll bursts.
STATUS_CACHE_TTL_MS=5000

# Meeting lifecycle
CHECKIN_GRACE_MIN=10      # minutes after start before a no-show is auto-released
AUTO_RELEASE=true         # mock: free no-show kiosk bookings (Graph handles no-shows via manual release only)

# Rate limiting for panel action endpoints (book / checkin / release / extend)
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=10000

# ── Live Microsoft Graph auth ────────────────────────────────────────────────
# Option A (POC): 1-hour delegated token from Graph Explorer
#   https://developer.microsoft.com/en-us/graph/graph-explorer
#   Sign in → avatar → Access token → paste here → restart backend
GRAPH_TEMP_TOKEN=

# Option B (production): Azure AD app registration — MSAL client-credentials flow.
# When all three are set, the backend refreshes tokens automatically and ignores
# GRAPH_TEMP_TOKEN. See docs/APP_REGISTRATION_REQUEST.md and docs/PHASE2_PLAN.md.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
