# backend/.env.example — copy to .env and fill in values
USE_MOCK_DATA=false
PORT=3000

# POC: 1-hour token from Graph Explorer (https://developer.microsoft.com/en-us/graph/graph-explorer)
# Sign in → avatar → Access token → paste here → restart backend
GRAPH_TEMP_TOKEN=paste-your-token-here

# Azure AD — get from IT Security or Azure Portal app registration (for future MSAL integration)
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
