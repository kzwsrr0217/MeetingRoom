# Root .env.example — copy to .env (chmod 600, git-ignored) for docker/podman compose.
# Compose substitutes these ${VARS} in docker-compose.prod.yml.

# mock = simulated data (no Azure). Set false once the Azure app registration exists.
USE_MOCK_DATA=true

# Host ports. Change these if the app server VM already uses 8080/3000.
# FRONTEND_PORT is the only one tablets connect to; the backend binds to localhost.
FRONTEND_PORT=8080
BACKEND_PORT=3000

# Protects admin/mutating endpoints. Generate a strong random value before go-live.
# In the Admin UI (System → Admin kulcs) paste the same value on each admin browser.
ADMIN_API_KEY=

# Frontend origin for CORS. With the nginx same-origin proxy you can leave the default.
FRONTEND_URL=http://localhost:8080

# ── Live Microsoft Graph auth ────────────────────────────────────────────────
# Preferred: Azure AD app registration (MSAL client-credentials, auto-refresh).
# The backend switches to MSAL automatically as soon as all three are set.
# See docs/APP_REGISTRATION_REQUEST.md to request these from Global IT.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Fallback only (POC): a 1-hour delegated token from Graph Explorer.
# Ignored when the AZURE_* values above are present.
GRAPH_TEMP_TOKEN=
